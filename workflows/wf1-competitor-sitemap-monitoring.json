      "id": "dt-upsert-snapshot",
      "name": "DT Upsert Snapshot"
    },
    {
      "parameters": {
        "jsCode": "/**\n * Slack builder — always outputs 1 item\n * Mode: Run once for all items\n *\n * Input: items = 1 item per site from \"Changes detected\" (passed through DT Upsert)\n * Output: 1 item:\n *   {\n *     hasChanges: boolean,\n *     message: string,\n *     sitesWithAdds: number,\n *     totalAdded: number\n *   }\n */\n\nconst MAX_URLS_PER_SITE = 50;\nconst IGNORE_BASELINE = true;\n\n// ===== DOMAIN EXCLUSION LIST =====\n// Exclude your own domain if you don't want self-notifications\nconst EXCLUDE_FROM_SLACK = [\n  'www.your-own-domain.com',\n  'your-own-domain.com',\n  // Add more domains to exclude from Slack notifications here\n];\n\nconst sites = items.map(i => i.json);\n\n// Keep only sites with additions (optionally ignore baseline runs)\n// AND exclude domains we don't want in Slack\nconst withAdds = sites\n  .filter(s => (IGNORE_BASELINE ? !s.isFirstRunForSite : true))\n  .filter(s => (s.addedCount || 0) > 0)\n  .filter(s => !EXCLUDE_FROM_SLACK.includes(s.site.toLowerCase()));\n\nconst hasChanges = withAdds.length > 0;\n\nlet message = \"\";\nlet totalAdded = 0;\n\nif (hasChanges) {\n  const lines = [];\n  lines.push(\"\\ud83d\\uddfa\\ufe0f *Sitemap monitoring \\u2014 New URLs detected*\");\n  lines.push(\"\");\n\n  for (const s of withAdds) {\n    const added = Array.isArray(s.added) ? s.added : [];\n    const shown = added.slice(0, MAX_URLS_PER_SITE);\n    const remaining = (s.addedCount || added.length) - shown.length;\n\n    totalAdded += (s.addedCount || added.length);\n\n    lines.push(`\\ud83d\\udd39 *${s.site}*`);\n    lines.push(`\\u2795 Added (${s.addedCount})`);\n    lines.push(shown.map(u => `\\u2022 ${u}`).join(\"\\n\"));\n\n    if (remaining > 0) {\n      lines.push(`\\u2026and ${remaining} more`);\n    }\n\n    lines.push(\"\");\n  }\n\n  message = lines.join(\"\\n\");\n}\n\nreturn [{\n  json: {\n    hasChanges,\n    message,\n    sitesWithAdds: withAdds.length,\n    totalAdded,\n  }\n}];\n"
      },
