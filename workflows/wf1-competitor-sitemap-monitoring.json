    {
      "parameters": {
        "jsCode": "const SNAPSHOT_NODE_NAME = 'DT Get Snapshots';\n\n// ---------- helpers ----------\nfunction getHostnameFromUrl(u) {\n  const s = String(u || '').trim();\n  const m = s.match(/^https?:\\/\\/([^\\/?#:]+)(?::\\d+)?/i);\n  return m ? m[1].toLowerCase() : null;\n}\n\nfunction normalizeUrl(u) {\n  return String(u || '')\n    .trim()\n    .replace(/#.*$/, '')   // drop fragments\n    .replace(/\\/+$/, '')   // remove trailing slashes\n    .toLowerCase();\n}\n\n// ---------- 1) Load previous snapshots from Data Table ----------\nconst snapshotRows = $items(SNAPSHOT_NODE_NAME) || [];\nconst previousBySite = {};\n\nfor (const r of snapshotRows) {\n  const site = String(r.json.site || '').trim().toLowerCase();\n  if (!site) continue;\n\n  let arr;\n  try {\n    arr = JSON.parse(r.json.urls_json || '[]');\n  } catch {\n    arr = [];\n  }\n\n  if (!Array.isArray(arr)) arr = [];\n  previousBySite[site] = arr.map(normalizeUrl);\n}\n\n// ---------- 2) Group current URLs by site + track fetch errors ----------\nconst currentBySite = {};\nconst skipped = [];\nconst fetchErrorSites = new Set();\n\nfor (const item of items) {\n  // Check if this item is a fetch error (from continueRegularOutput)\n  if (item.json.error || item.json.$error) {\n    const errorUrl = item.json.$request?.url || item.json.loc || '';\n    const errorSite = getHostnameFromUrl(errorUrl);\n    if (errorSite) {\n      fetchErrorSites.add(errorSite);\n    }\n    skipped.push({ reason: 'fetch_error', url: errorUrl, error: item.json.error?.message || 'Unknown error' });\n    continue;\n  }\n  \n  const locRaw = item.json.loc;\n  if (!locRaw) {\n    skipped.push({ reason: 'missing_loc', item: item.json });\n    continue;\n  }\n\n  const loc = normalizeUrl(locRaw);\n\n  const site =\n    (item.json.site && String(item.json.site).trim().toLowerCase()) ||\n    getHostnameFromUrl(loc);\n\n  if (!site) {\n    skipped.push({ reason: 'cannot_derive_site', loc: locRaw });\n    continue;\n  }\n\n  if (!/^https?:\\/\\//i.test(loc)) {\n    skipped.push({ reason: 'not_absolute_url', loc: locRaw });\n    continue;\n  }\n\n  if (!currentBySite[site]) currentBySite[site] = [];\n  currentBySite[site].push(loc);\n}\n\n// ---------- 3) Diff per site + prepare snapshot for upsert ----------\n// Skip sites with fetch errors to preserve their existing Data Table state\nconst out = [];\n\nfor (const site of Object.keys(currentBySite).sort()) {\n  if (fetchErrorSites.has(site)) {\n    continue;\n  }\n  \n  const currentRaw = currentBySite[site];\n  const currentUnique = Array.from(new Set(currentRaw)).sort();\n\n  const previous = previousBySite[site] || [];\n  const previousSet = new Set(previous);\n  const currentSet = new Set(currentUnique);\n\n  const added = currentUnique.filter(u => !previousSet.has(u));\n  const removed = previous.filter(u => !currentSet.has(u));\n\n  out.push({\n    json: {\n      site,\n      urls_json: JSON.stringify(currentUnique),\n      previousCount: previous.length,\n      isFirstRunForSite: previous.length === 0,\n      totalUrls: currentRaw.length,\n      uniqueUrls: currentUnique.length,\n      duplicateCount: currentRaw.length - currentUnique.length,\n      addedCount: added.length,\n      removedCount: removed.length,\n      added: added.slice(0, 50),\n      removed: removed.slice(0, 50),\n      _debug: {\n        dtRows: snapshotRows.length,\n        skippedCount: skipped.length,\n        skippedSample: skipped.slice(0, 5),\n        fetchErrorSites: Array.from(fetchErrorSites),\n      }\n    }\n  });\n}\n\nreturn out;\n"
      },
